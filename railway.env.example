# ── Railway Dashboard → Service → Variables ───────────────────────────────────
# DATABASE_URL підставляється автоматично, якщо додати PostgreSQL plugin
# і зробити Reference: ${{Postgres.DATABASE_URL}}
#
# Після Generate Domain онови URL у двох змінних нижче.

NODE_ENV=production
DATABASE_SSL=true

TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_USERNAME=pic2recipe_bot
TELEGRAM_MINI_APP_URL=https://your-app.up.railway.app
TELEGRAM_WEBHOOK_SECRET=your_random_webhook_secret

GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.5-flash

CORS_ORIGIN=https://your-app.up.railway.app
PREMIUM_PRICE_STARS=50
DAILY_FREE_LIMIT=3

# Build-time (Dockerfile ARG) — Railway передає Variables під час збірки:
# VITE_API_URL=/api  (дефолт у Dockerfile)
# VITE_TELEGRAM_BOT_USERNAME — береться з TELEGRAM_BOT_USERNAME вище

# PEXELS_API_KEY=
# UNSPLASH_ACCESS_KEY=
