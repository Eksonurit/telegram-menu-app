# Відносний шлях для dev+ngrok (через Vite proxy) або повний URL для продакшену
# Приклад prod: https://your-api.example.com/api
VITE_API_URL=/api

# Порт dev-сервера Vite
VITE_DEV_PORT=5173

# Базовий шлях для деплою (наприклад, /app/ якщо TMA хоститься в підпапці)
VITE_BASE_PATH=/

# Ім'я бота Telegram (для посилань та дебагу)
VITE_TELEGRAM_BOT_USERNAME=your_bot_username
