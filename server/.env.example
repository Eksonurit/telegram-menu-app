# Сервер
PORT=3000
NODE_ENV=development

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_USERNAME=pic2recipe_bot

# URL Mini App (для налаштування Menu Button у BotFather)
TELEGRAM_MINI_APP_URL=https://your-domain.com

# Коротке ім'я Direct Link Mini App з BotFather (/newapp), якщо створювали
# TELEGRAM_MINI_APP_SHORT_NAME=your_short_name

# Секрет вебхука (необов'язково, але рекомендовано в продакшні).
# Той самий рядок передається у setWebhook(secret_token=...) і перевіряється
# на ендпоінті POST /api/payments/webhook через заголовок
# X-Telegram-Bot-Api-Secret-Token. Дозволені символи: A-Z a-z 0-9 _ -
# TELEGRAM_WEBHOOK_SECRET=your_random_webhook_secret

# ── Платежі Telegram Stars ───────────────────────────────────────────────────
# Provider token НЕ потрібен для Stars (currency=XTR, provider_token="").
# Ціна преміуму в зірках (необов'язково; за замовчуванням 50).
# PREMIUM_PRICE_STARS=50

# CORS — URL фронтенду (через кому для кількох origin)
CORS_ORIGIN=http://localhost:5173

# База даних (PostgreSQL) — обов'язково: зберігає преміум-статуси та ліміти.
# Таблиці (user_credits, referral_events) створюються автоматично при старті сервера.
#
# Локально через Docker Compose (docker compose up db -d):
#   DATABASE_URL=postgresql://user:password@localhost:5435/recipe_mini_app
DATABASE_URL=postgresql://user:password@localhost:5432/recipe_mini_app

# Увімкніть SSL, якщо БД хмарна (Neon / Supabase / Heroku тощо). Для локального — не треба.
# DATABASE_SSL=true

# ШІ-провайдер — Google Gemini (обов'язково для аналізу фото)
# Отримати ключ безкоштовно: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Назва моделі Gemini (необов'язково; за замовчуванням gemini-2.5-flash)
# Альтернативи: gemini-2.0-flash, gemini-2.5-pro, gemini-1.5-flash
# GEMINI_MODEL=gemini-2.5-flash

# OpenAI (резервний провайдер, наразі не використовується)
# OPENAI_API_KEY=your_openai_api_key

# ── Пошук фото їжі (необов'язково — без ключів рецепти відображаються без фото) ──
# Pexels (пріоритет, 200 req/год безкоштовно): https://www.pexels.com/api/
# PEXELS_API_KEY=your_pexels_api_key_here

# Unsplash (резерв, 50 req/год безкоштовно): https://unsplash.com/developers
# UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here
